def _find_agent_browser() -> str | None:
    """Return the chrome-use binary path, or None if it isn't installed."""
    for name in AB_BIN_CANDIDATES:
        path = shutil.which(name)
        if path:
            return path
    return None


def _version_tuple(v: str) -> tuple[int, ...]:
    """Parse a dotted version like '1.5.23' into (1, 5, 23); junk → (0,)."""
    nums = re.findall(r"\d+", v or "")
    return tuple(int(n) for n in nums[:3]) or (0,)


# ---------- terminal output (color, TTY-aware) ----------
# Color is only ever applied to the stderr progress timeline and the `doctor`
# report — stdout stays plain (it carries exactly the saved path, for `$(...)`).

_WARN_WORDS = ("warning", "unavailable", "could not", "couldn't", "failed",
               "stall", "not connected")


def _use_color(stream=None) -> bool:
    """True if we should emit ANSI color to ``stream`` (default stderr).

    Only when it's a real TTY and color isn't disabled — honors NO_COLOR
    (https://no-color.org), CHATGPT_IMAGEGEN_NO_COLOR, and TERM=dumb. So piping
    or redirecting (e.g. `2>log`) yields clean plain text automatically."""
    if stream is None:
        stream = sys.stderr
    if os.environ.get("NO_COLOR") or os.environ.get("CHATGPT_IMAGEGEN_NO_COLOR"):
        return False
    if (os.environ.get("TERM") or "").lower() == "dumb":
        return False
    try:
        return bool(stream.isatty())
    except Exception:  # noqa: BLE001
        return False


def _paint(code: str, s: str, *, stream=None) -> str:
    """Wrap ``s`` in ANSI SGR ``code`` when color is on for ``stream``, else
    return it unchanged."""
    return f"\033[{code}m{s}\033[0m" if _use_color(stream) else s


def _dim(s: str, **kw) -> str: return _paint("2", s, **kw)
def _red(s: str, **kw) -> str: return _paint("31", s, **kw)
def _green(s: str, **kw) -> str: return _paint("32", s, **kw)
def _yellow(s: str, **kw) -> str: return _paint("33", s, **kw)


def _fmt_progress(elapsed: float, msg: str) -> str:
    """One stderr progress line: a dimmed `[  N.Ns]` timestamp + message, with
    warning-ish messages tinted yellow. Plain when color is off."""
    line = f"{_dim(f'[{elapsed:6.1f}s]')} "
    low = msg.lower()
    return line + (_yellow(msg) if any(w in low for w in _WARN_WORDS) else msg)


def _chrome_use_version(ab: str) -> str | None:
    """chrome-use's dotted version (e.g. '1.5.28'), or None if unreadable.
    Shared by the old-version warning and `doctor`."""
    try:
        out = subprocess.run([ab, "--version"], capture_output=True, text=True,
                             timeout=10)
    except Exception:  # noqa: BLE001
        return None
    m = re.search(r"\d+\.\d+\.\d+", (out.stdout or out.stderr or "").strip())
    return m.group(0) if m else None


def _warn_if_chrome_use_old(ab: str, emit) -> None:
    """Soft-warn (never block) if chrome-use is below AB_MIN_VERSION.

    The web backend's img2img (`upload`) and model switch (coordinate `click`)
    need a recent chrome-use; an old binary fails them with an opaque exit code.
    Best-effort: if `--version` can't be read or parsed, stay quiet.
    """
    v = _chrome_use_version(ab)
    if v and _version_tuple(v) < _version_tuple(AB_MIN_VERSION):
        emit(
            f"warning: chrome-use {v} is older than {AB_MIN_VERSION}; "
            f"image-to-image / model-switch may fail. Update with the installer "
            f"at github.com/leeguooooo/chrome-use."
        )


